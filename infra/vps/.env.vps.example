# =============================================================================
# COMENOR — variables del VPS MAW Soluciones (docker-compose)
# Copia a `.env.vps` en el VPS y llena con valores REALES. NUNCA lo subas a git.
# Arranque:  docker compose --env-file .env.vps up -d
# =============================================================================

# --- Dominios (deben apuntar por DNS al VPS; ver RUNBOOK.md) -----------------
# S3 API de MinIO, público (la app entrega URLs firmadas de vida corta).
STORAGE_DOMAIN=storage.comenor.org.mx
# Gotenberg, protegido por token (401 sin Authorization: Bearer correcto).
DOCS_DOMAIN=docs.comenor.org.mx

# --- ACME / Let's Encrypt ----------------------------------------------------
# Correo para avisos de expiración de certificados TLS.
ACME_EMAIL=infraestructura@comenor.org.mx

# --- MinIO: credenciales root (superusuario del almacenamiento) --------------
# Genera valores largos y aleatorios:  openssl rand -hex 24
# La app NO usa estas llaves: usa una llave de servicio acotada (ver RUNBOOK).
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# URL a la que la consola de MinIO redirige tras login (solo por túnel SSH).
MINIO_CONSOLE_URL=http://localhost:9001

# --- Gotenberg: token de acceso ----------------------------------------------
# El MISMO valor va en GOTENBERG_TOKEN de la app (Vercel). Genera:
#   openssl rand -base64 48
GOTENBERG_TOKEN=

# =============================================================================
# Referencia — bucket y llave de servicio que la app espera (se CREAN a mano
# con `mc` tras el primer arranque; ver docs/RUNBOOK.md). No los consume
# docker-compose, se documentan aquí para tener todo el contrato en un lugar:
#
#   Bucket físico único (privado):        comenor
#   Prefijos lógicos dentro del bucket:   documentos/  memorias/  eventos/
#   Llave de servicio de la app:          S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY
#                                         (política acotada al bucket `comenor`)
# =============================================================================
