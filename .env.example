# =============================================================================
# COMENOR — contrato de variables de entorno de la app (Next.js en Vercel)
# Copia este archivo a .env.local y llena los valores.
# Secretos reales SOLO en los dashboards de Vercel/Neon. Jamás en git.
#
# Arquitectura (ver docs/DECISIONES.md, ADR-006): infra propia, sin BaaS externo.
#   - DB     : Neon Postgres (Drizzle)
#   - Auth   : better-auth dentro de Next, sesiones en Neon
#   - Storage: MinIO (S3) en el VPS MAW — URLs firmadas de vida corta
#   - PDF    : Gotenberg en el VPS MAW — conversión Word/Excel → PDF del visor
# =============================================================================

# --- Base de datos (Neon Postgres) -------------------------------------------
# Cadena de conexión con sslmode=require. Fuente de verdad de datos Y de auth.
DATABASE_URL=

# --- Autenticación (better-auth sobre Neon) ----------------------------------
# Secreto de firma de sesiones. Genera uno con: openssl rand -base64 32
BETTER_AUTH_SECRET=
# URL base de la app (local: http://localhost:3000; prod: la URL canónica).
BETTER_AUTH_URL=
# Opcional: "true" habilita el registro público. Por defecto SOLO el admin da
# de alta usuarios; el sign-up de better-auth queda deshabilitado.
AUTH_PERMITIR_REGISTRO=
# Correos con rol admin efectivo (coma-separados). Un usuario con rol='admin'
# que NO esté en esta lista se trata como sin rol (falla cerrada).
ADMIN_ALLOWED_EMAILS=

# --- Sitio -------------------------------------------------------------------
# URL canónica pública (local: http://localhost:3000). Se usa para armar
# enlaces absolutos en correos y metadata; NUNCA se deriva del header Host.
NEXT_PUBLIC_SITE_URL=

# --- Almacenamiento S3 / MinIO (VPS MAW) — SOLO SERVIDOR ----------------------
# Endpoint del S3 API publicado por Caddy (prod: https://storage.comenor.org.mx;
# dev local: http://localhost:9000).
S3_ENDPOINT=
# MinIO ignora la región pero el SDK la exige. Usa us-east-1.
S3_REGION=us-east-1
# Llave de servicio ACOTADA al bucket (NO las credenciales root de MinIO).
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Bucket físico único; los buckets lógicos (documentos|memorias|eventos) son
# prefijos dentro de él.
S3_BUCKET=comenor
# Opcional: base pública para objetos servidos sin firma (solo portadas de
# eventos). Fallback: {S3_ENDPOINT}/{S3_BUCKET}. Documentos y memorias JAMÁS
# usan esto — van siempre por URL firmada.
S3_PUBLIC_URL=

# --- Conversión de documentos (Gotenberg, VPS MAW) — SOLO SERVIDOR -----------
# URL del Gotenberg publicado por Caddy (prod: https://docs.comenor.org.mx).
GOTENBERG_URL=
# Token que Caddy exige como `Authorization: Bearer …` (== GOTENBERG_TOKEN del
# VPS en infra/vps/.env.vps). Genera: openssl rand -base64 48
GOTENBERG_TOKEN=

# --- Mercado Pago (sandbox en staging; credenciales productivas SOLO en prod) -
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# --- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=notificaciones@comenor.org.mx

# --- Seguridad ---------------------------------------------------------------
# Firma HMAC de los QR de acceso a eventos. Genera: openssl rand -base64 32
QR_SIGNING_SECRET=

# --- Rate limiting (Upstash Redis; opcional) ---------------------------------
# Sin estas variables se usa un fallback en memoria (no sirve en serverless
# multi-instancia; configúralas en prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Observabilidad ----------------------------------------------------------
SENTRY_DSN=
